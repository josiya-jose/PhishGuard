{
"manifest_version": 3,
"name": "PhishGuard - URL Safety Detector",
"version": "1.0.0",
"description": "Detects phishing URLs using ML-powered ensemble analysis",

"permissions": [
"activeTab",
"tabs",
"notifications",
"webNavigation",
"storage"
],

"host_permissions": [
"http://*/*",
"https://*/*",
"http://localhost:8000/*"
],

"action": {
"default_popup": "popup.html",
"default_icon": {
"16": "icons/icon16.png",
"48": "icons/icon48.png",
"128": "icons/icon128.png"
}
},

"background": {
"service_worker": "background.js"
},

"content_scripts": [
{
"matches": ["http://*/*", "https://*/*"],
"js": ["content.js"],
"run_at": "document_idle"
}
],

"web_accessible_resources": [
{
"resources": ["warning.html"],
"matches": ["<all_urls>"]
}
],

"icons": {
"16": "icons/icon16.png",
"48": "icons/icon48.png",
"128": "icons/icon128.png"
},

"content_security_policy": {
"extension_pages": "script-src 'self'; object-src 'self'"
}
}
